with "../backup.gpr";
with "../../project_tools/project_tools.gpr";
with "config/tests_config.gpr";
project Tests is

   Target_OS := external ("BACKUP_TARGET_OS", Tests_Config.Alire_Host_OS);

   for Source_Dirs use
     ("src/",
      "config/",
      "../../HttpClient/tests/src/");
   for Object_Dir use "obj/" & Target_OS & "/" & Tests_Config.Build_Profile;
   for Create_Missing_Dirs use "True";
   for Exec_Dir use "bin";
   for Main use ("tests.adb", "backup_http_remote_live_tests.adb");

   package Compiler is
      for Default_Switches ("Ada") use ("-gnat2022", "-gnata", "-gnatW8", "-gnatwa", "-gnatVa");
      for Switches ("http_client-ada_test_fixtures.adb") use
        ("-gnat2022", "-gnata", "-gnatW8", "-gnatws", "-gnatVa");
   end Compiler;

   package Binder is
      for Switches ("Ada") use ("-Es"); --  Symbolic traceback
   end Binder;

   package Linker is
      for Default_Switches ("Ada") use ("-lssl", "-lcrypto");
   end Linker;

   package Install is
      for Artifacts (".") use ("share");
   end Install;

end Tests;
